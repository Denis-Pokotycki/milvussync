DJANGO_SECRET_KEY=change-me
DEBUG=True
DJANGO_ENVIRONMENT=development

# --- Pulsar ---
PULSAR_URL=pulsar://localhost:6650
PULSAR_NAMESPACE=default
PULSAR_TENANT=public
PULSAR_TOPIC=tender-title-sync

# --- Milvus (legacy tenders collection) ---
MILVUS_URI=http://host.docker.internal:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=tenders
MILVUS_VECTOR_DIM=1536

# --- Milvus (tender_search demo collection) ---
TENDER_SEARCH_COLLECTION=tender_search
TENDER_SEARCH_VECTOR_DIM=1024

# --- OpenAI (legacy consumer) ---
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# --- BGE embedding model ---
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# --- PostgreSQL (demo data source) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tenders
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_SSL_MODE=prefer

# --- Sync producer ---
SYNC_BATCH_SIZE=100
SYNC_POLL_INTERVAL_SECONDS=30
SYNC_STATE_FILE=sync_state.json

# --- Consumer tuning ---
MILVUS_SYNC_UNACKED_TIMEOUT_MS=300000
